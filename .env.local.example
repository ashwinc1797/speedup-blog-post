# SpeedUp Infotech — Blog Automation Environment Variables
# Copy this file to .env.local and fill in your keys

# REQUIRED — Get free from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL — Get free from: https://unsplash.com/developers
# Without this, fallback Unsplash source URLs are used (still works)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# OPTIONAL — Any random string for IndexNow search engine submission
INDEXNOW_KEY=speedup2026pune

# OPTIONAL — From Vercel: Project > Settings > Git > Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_xxxxx
