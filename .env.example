# SpeedUp Blog Automation — Local Environment
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — your keys are safe.

# Required: your Groq API key (free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# Optional: second Groq key for automatic rate-limit rotation
# GROQ_API_KEY_2=gsk_your_second_key_here

# Optional: third Groq key
# GROQ_API_KEY_3=gsk_your_third_key_here

# Optional: Pexels API key for real image fetching (free at https://www.pexels.com/api/)
# PEXELS_API_KEY=your_pexels_key_here

# Optional: Unsplash API key (fallback image source)
# UNSPLASH_ACCESS_KEY=your_unsplash_key_here
